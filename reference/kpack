"""kpack — thin launcher for the reference CLI.

The implementation lives in kpack_cli.py (an importable module, and the
`kpack` console-script entry point declared in pyproject.toml). This file
keeps the documented `./reference/kpack` invocation working from a plain
checkout with no install step.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from kpack_cli import main

if __name__ == "__main__":
    sys.exit(main())
