# EditorConfig - Universal formatting rules
# https://editorconfig.org

root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Shell scripts (.sh extension)
[*.sh]
indent_size = 4
shell_variant = bash

# Scripts without extension (use shebangs to indicate interpreter)
[scripts/*]
indent_size = 4

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = 100

# TOML
[*.toml]
indent_size = 2

# JSON
[*.json]
indent_size = 2
